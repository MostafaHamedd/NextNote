# Option A — same machine, browser calls API directly:
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Option B — recommended for phone / LAN testing: browser uses Next as a proxy (no direct :8000).
# Run FastAPI on this machine (e.g. uvicorn on 127.0.0.1:8000). Restart `npm run dev` after edits.
NEXT_PUBLIC_API_URL=/api/backend
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
